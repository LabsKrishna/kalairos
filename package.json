{
  "name": "kalairos",
  "version": "1.7.0",
  "description": "Agent platform with bitemporal memory, live observability, and audit-grade traceability — for AI that needs to act at the right moment",
  "main": "./index.js",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./server": {
      "import": "./server.mjs",
      "require": "./server.js",
      "default": "./server.js"
    },
    "./remote": {
      "import": "./remote.mjs",
      "require": "./remote.js",
      "default": "./remote.js"
    },
    "./mcp": {
      "import": "./mcp.mjs",
      "require": "./mcp.js",
      "default": "./mcp.js"
    }
  },
  "bin": {
    "kalairos": "bin/cli.js",
    "kalairos-mcp": "mcp.js"
  },
  "scripts": {
    "start": "node server.js",
    "postinstall": "node scripts/download-model.js || true",
    "test": "node tests/test-basic.js && node tests/test-versioning.js && node tests/test-temporal-behavior.js && node tests/test-series-supersession.js && node tests/test-agent-simulation.js && node tests/test-scope.js && node tests/test-sqlite-index.js && node tests/test-sqlite-integration.js",
    "test:services": "node --test services/dep-graph-builder/test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov npm test",
    "bench": "node bench/agent-memory/run-all.js",
    "bench:real": "node bench/agent-memory/bench-eval-real.js",
    "bench:latency": "node bench/latency.js",
    "bench:poisoning": "node bench/poisoning/run.js",
    "bench:longmemeval": "node bench/longmemeval/run.js"
  },
  "keywords": [
    "agent-platform",
    "ai-agent",
    "agent-runtime",
    "agent-observability",
    "control-plane",
    "bitemporal",
    "audit-trail",
    "provenance",
    "agent-memory",
    "ai-memory",
    "llm-memory",
    "memory-layer",
    "versioned-memory",
    "temporal-memory",
    "semantic-memory",
    "long-term-memory",
    "knowledge-graph",
    "autonomous-agent",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "local-first",
    "private-ai",
    "memory-poisoning",
    "prompt-injection",
    "ai-safety"
  ],
  "author": "KrishnaLabsLLC <main@krishnalabs.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LabsKrishna/kalairos.git"
  },
  "bugs": {
    "url": "https://github.com/LabsKrishna/kalairos/issues"
  },
  "homepage": "https://github.com/LabsKrishna/kalairos#readme",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/LabsKrishna"
  },
  "devDependencies": {
    "c8": "^10.1.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.0.0",
    "express": "^5.2.1"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.25.1"
  },
  "files": [
    "README.md",
    "llms.txt",
    "index.js",
    "index.mjs",
    "server.js",
    "server.mjs",
    "remote.js",
    "remote.mjs",
    "kernel.js",
    "versioning.js",
    "trust.js",
    "worker-pool.js",
    "worker.js",
    "bin/cli.js",
    "errors.js",
    "agent.js",
    "auth.js",
    "embedder.js",
    "tokenizer.json",
    "scripts/download-model.js",
    "mcp.js",
    "mcp.mjs",
    "store/entity-normalizer.js",
    "store/file-store.js",
    "store/sqlite-index.js",
    "examples/demo.js"
  ]
}
